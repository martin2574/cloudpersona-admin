{
  "name": "yourq-admin",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npx tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript http://localhost:3057/openapi.json -o src/types/api-types.ts",
    "lint": "eslint src/ server.ts",
    "prepare": "husky",
    "postinstall": "prisma generate --schema=prisma/backoffice/schema.prisma"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ginkgo-bioworks/react-json-schema-form-builder": "^4.1.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@rjsf/core": "^6.4.1",
    "@rjsf/utils": "^6.4.1",
    "@rjsf/validator-ajv8": "^6.4.1",
    "@yourq/rjsf-theme": "file:../cloudpersona-ui/packages/rjsf-theme",
    "@yourq/tokens": "file:../cloudpersona-ui/packages/tokens",
    "@yourq/ui": "file:../cloudpersona-ui/packages/ui",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.1",
    "express": "^5.1.0",
    "lucide-react": "^0.577.0",
    "pino": "^10.3.1",
    "pino-http": "^10.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "sonner": "^1.7.4",
    "tw-animate-css": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.2"
  }
}
